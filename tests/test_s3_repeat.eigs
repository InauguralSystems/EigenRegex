# S3: repetition * + ? (greedy and lazy)

load_file of "lib/regex.eigs"

define check(label, got, want) as:
    if got == want:
        print of (label + " OK")
    else:
        print of (label + " FAIL")
        print of "  got:"
        print of got
        print of "  want:"
        print of want
    return 0

# ---- star (greedy) ----
prog is re_compile of "a*"
check of ["a* matches empty", re_match of [prog, ""], 1]
check of ["a* matches a", re_match of [prog, "a"], 1]
check of ["a* matches aaaa", re_match of [prog, "aaaa"], 1]
check of ["a* does not match b (anchored)", re_match of [prog, "b"], 0]
check of ["a* does not match ab (anchored)", re_match of [prog, "ab"], 0]

# ---- star with concat ----
prog is re_compile of "ab*c"
check of ["ab*c matches ac", re_match of [prog, "ac"], 1]
check of ["ab*c matches abc", re_match of [prog, "abc"], 1]
check of ["ab*c matches abbbbc", re_match of [prog, "abbbbc"], 1]
check of ["ab*c does not match a", re_match of [prog, "a"], 0]
check of ["ab*c does not match abx", re_match of [prog, "abx"], 0]

# ---- plus ----
prog is re_compile of "a+"
check of ["a+ does not match empty", re_match of [prog, ""], 0]
check of ["a+ matches a", re_match of [prog, "a"], 1]
check of ["a+ matches aaaa", re_match of [prog, "aaaa"], 1]
check of ["a+ does not match b", re_match of [prog, "b"], 0]

prog is re_compile of "ab+c"
check of ["ab+c does not match ac", re_match of [prog, "ac"], 0]
check of ["ab+c matches abc", re_match of [prog, "abc"], 1]
check of ["ab+c matches abbbc", re_match of [prog, "abbbc"], 1]

# ---- question ----
prog is re_compile of "colou?r"
check of ["colou?r matches color", re_match of [prog, "color"], 1]
check of ["colou?r matches colour", re_match of [prog, "colour"], 1]
check of ["colou?r does not match colouur", re_match of [prog, "colouur"], 0]

# ---- combined with alternation ----
prog is re_compile of "(ab)+|c"
check of ["(ab)+|c matches ab", re_match of [prog, "ab"], 1]
check of ["(ab)+|c matches abab", re_match of [prog, "abab"], 1]
check of ["(ab)+|c matches ababab", re_match of [prog, "ababab"], 1]
check of ["(ab)+|c matches c", re_match of [prog, "c"], 1]
check of ["(ab)+|c does not match aba", re_match of [prog, "aba"], 0]
check of ["(ab)+|c does not match empty", re_match of [prog, ""], 0]

# ---- greedy vs lazy via search end position ----
# Greedy: a.*b on "axxxbxxxb" should match the WHOLE thing (to the last b).
# Note: . is S4, so use plus instead: "ab+" on "abbbb" should consume all b's.
prog is re_compile of "ab+"
r is re_search of [prog, "abbbb"]
check of ["greedy ab+ end at pos 5", r[1], 5]

prog is re_compile of "ab+?"
r is re_search of [prog, "abbbb"]
check of ["lazy ab+? end at pos 2", r[1], 2]

prog is re_compile of "a*"
r is re_search of [prog, "aaab"]
check of ["greedy a* leftmost end at pos 3", r[1], 3]

prog is re_compile of "a*?"
r is re_search of [prog, "aaab"]
check of ["lazy a*? leftmost end at pos 0", r[1], 0]

# ---- find_all with greedy + ----
prog is re_compile of "a+"
all is re_find_all of [prog, "aaabaaab"]
check of ["find_all a+ count", len of all, 2]
check of ["find_all a+ first ends at 3", all[0][1], 3]
check of ["find_all a+ second ends at 7", all[1][1], 7]

# ---- parse error: bare quantifier ----
prog is re_compile of "*a"
check of ["bare * returns null", prog, null]

prog is re_compile of "+a"
check of ["bare + returns null", prog, null]

prog is re_compile of "a**"
check of ["a** returns null", prog, null]

# ---- nested repetition ----
prog is re_compile of "(a+)+"
check of ["(a+)+ matches aaaa", re_match of [prog, "aaaa"], 1]
check of ["(a+)+ does not match empty", re_match of [prog, ""], 0]

print of "==="
print of "all S3 checks emitted"
